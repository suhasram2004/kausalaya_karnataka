rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128; }
    
    match /workers/{workerId} {
      allow read: if true;
      allow write: if isSignedIn(); // Simplified for now, should be owner check
      
      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isSignedIn();
      }
    }
    
    match /requests/{requestId} {
      allow create: if true; // Customers can request without auth for ease? Or maybe better with auth
      allow read, update: if isSignedIn();
    }
  }
}
